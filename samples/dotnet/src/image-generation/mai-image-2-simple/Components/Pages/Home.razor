@page "/"
@rendermode InteractiveServer
@using MaiImage2Simple.Models
@using MaiImage2Simple.Services
@inject IMaiImageService MaiImageService
@inject Microsoft.Extensions.Options.IOptions<MicrosoftFoundryOptions> FoundryOptions

<PageTitle>MAI Image Generator</PageTitle>

<h1>MAI Image Generator</h1>

<p>Enter a prompt, choose a model and output size, and generate an image.</p>

<section class="alert alert-info" role="note">
	<h2 class="h5">Configure Foundry connection</h2>
	<p class="mb-2">Set these values in appsettings.json or environment variables before running.</p>
	<ul class="mb-2">
		<li>Endpoint: use your Foundry resource endpoint, for example https://msf-foundrysandbox.services.ai.azure.com</li>
		<li>Deployment: set your default model deployment name, for example MAI-Image-2 or MAI-Image-2-Efficient</li>
		<li>API key: set the key from your Foundry resource</li>
	</ul>
	<p class="mb-2">Available models:</p>
	<ul class="mb-2">
		<li><strong>MAI-Image-2</strong> — best for complex, richly detailed scenes and long prompts.</li>
		<li><strong>MAI-Image-2-Efficient</strong> — ~22–23% faster and ~4× more compute-efficient; ideal for high-volume, real-time, or prototyping use cases.</li>
	</ul>
	<p class=\"mb-2\">The app calls the MAI API route at /mai/v1/images/generations.</p>
	<p class=\"mb-2\">Authentication: set <code>MicrosoftFoundry__ApiKey</code> to use an API key, or leave it empty to use <strong>DefaultAzureCredential</strong> (managed identity or developer sign-in).</p>
	<pre class="mb-0"><code>MicrosoftFoundry__ResourceEndpoint=https://msf-foundrysandbox.services.ai.azure.com
MicrosoftFoundry__ImageDeployment=MAI-Image-2
MicrosoftFoundry__ApiKey=&lt;your-api-key-or-leave-empty-for-managed-identity&gt;</code></pre>
</section>

<EditForm Model="request" OnSubmit="GenerateImageAsync" class="image-form">
	<div class="mb-3">
		<label class="form-label" for="model">Model</label>
		<select id="model" class="form-select" @bind="request.Deployment">
			@foreach (var deployment in FoundryOptions.Value.AvailableDeployments)
			{
				<option value="@deployment">@deployment</option>
			}
		</select>
	</div>

	<div class="mb-3">
		<label class="form-label" for="prompt">Prompt</label>
		<textarea
			id="prompt"
			class="form-control"
			rows="4"
			maxlength="4000"
			@bind="request.Prompt"
			@bind:event="oninput"
			placeholder="Example: A watercolor landscape at sunrise"
			required>
		</textarea>
	</div>

	<div class="row g-3 mb-3">
		<div class="col-sm-6">
			<label class="form-label" for="width">Width</label>
			<input id="width" class="form-control" type="number" min="768" step="1" @bind="request.Width" />
		</div>
		<div class="col-sm-6">
			<label class="form-label" for="height">Height</label>
			<input id="height" class="form-control" type="number" min="768" step="1" @bind="request.Height" />
		</div>
	</div>

	<button class="btn btn-primary" type="submit" disabled="@isSubmitting">
		@(isSubmitting ? "Generating..." : "Generate image")
	</button>
</EditForm>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
	<div class="alert alert-danger mt-3" role="alert">
		@errorMessage
	</div>
}

@if (!string.IsNullOrWhiteSpace(imageDataUrl))
{
	<section class="image-panel mt-3" aria-live="polite">
		<h2>Generated image</h2>
		<img src="@imageDataUrl" alt="Generated from prompt" class="img-fluid" />
	</section>
}

@code {
	private readonly MaiImageRequest request = new();
	private bool isSubmitting;
	private string? errorMessage;
	private string? imageDataUrl;

	protected override void OnInitialized()
	{
		var defaults = FoundryOptions.Value;
		request.Width = defaults.DefaultWidth;
		request.Height = defaults.DefaultHeight;
		request.Deployment = defaults.ImageDeployment;
	}

	private async Task GenerateImageAsync()
	{
		if (isSubmitting)
		{
			return;
		}

		isSubmitting = true;
		errorMessage = null;
		imageDataUrl = null;

		try
		{
			var result = await MaiImageService.GenerateImageAsync(request);
			if (result.IsSuccess && !string.IsNullOrWhiteSpace(result.Base64Image))
			{
				imageDataUrl = $"data:image/png;base64,{result.Base64Image}";
				return;
			}

			errorMessage = result.ErrorMessage ?? "Image generation failed.";
		}
		finally
		{
			isSubmitting = false;
		}
	}
}

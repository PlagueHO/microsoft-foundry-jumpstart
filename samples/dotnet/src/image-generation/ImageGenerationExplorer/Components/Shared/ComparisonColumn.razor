@using ImageGenerationExplorer.Models

<MudCard Outlined="true" Style="min-width: 350px; max-width: 450px;">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                @Run.Timestamp.LocalDateTime.ToString("HH:mm:ss")
            </MudText>
            <MudText Typo="Typo.subtitle2" Class="mud-text-truncate">@Run.Prompt</MudText>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent>
        @foreach (var result in Run.Results)
        {
            <MudCard Outlined="true" Class="mb-2">
                <MudCardContent Class="pa-2">
                    <div class="d-flex justify-space-between align-center mb-1">
                        <MudText Typo="Typo.subtitle2">@result.DisplayName</MudText>
                        @if (result.IsSuccess)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">
                                @(result.ElapsedMs)ms
                            </MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Filled">
                                Error
                            </MudChip>
                        }
                    </div>
                    @if (result.IsSuccess && !string.IsNullOrWhiteSpace(result.Base64Image))
                    {
                        <MudImage Src="@($"data:image/png;base64,{result.Base64Image}")"
                                  Alt="@($"Generated by {result.DisplayName}")"
                                  Fluid="true" Class="rounded" />
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                            @(result.Width)×@(result.Height)
                        </MudText>
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Error" Dense="true" Class="mb-0">
                            @(result.ErrorMessage ?? "Generation failed.")
                            @if (result.StatusCode.HasValue)
                            {
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="ml-1">
                                    HTTP @result.StatusCode
                                </MudChip>
                            }
                        </MudAlert>
                    }
                </MudCardContent>
            </MudCard>
        }
    </MudCardContent>
    <MudCardActions>
        <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small" FullWidth="true"
                   StartIcon="@Icons.Material.Filled.Delete" OnClick="() => OnDelete.InvokeAsync(Run)">
            Delete
        </MudButton>
    </MudCardActions>
</MudCard>

@code {
    [Parameter]
    [EditorRequired]
    public ComparisonRun Run { get; set; } = default!;

    [Parameter]
    public EventCallback<ComparisonRun> OnDelete { get; set; }
}

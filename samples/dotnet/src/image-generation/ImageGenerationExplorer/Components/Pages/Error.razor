@page "/Error"

<PageTitle>Error — Image Generation Explorer</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudAlert Severity="Severity.Error" Variant="Variant.Filled">
        <MudText Typo="Typo.h5">An error occurred</MudText>
        <MudText Typo="Typo.body1" Class="mt-2">
            An unhandled error has occurred while processing your request.
        </MudText>
    </MudAlert>
</MudContainer>
